{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://topaz-racing.com/schemas/race-events-v1.schema.json",
  "title": "Topaz Racing Event Annotations V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["events"],
  "properties": {
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    }
  },
  "$defs": {
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["gybe", "wipeout", "sail_change", "tack", "mark_rounding", "note"]
        },
        "time": {
          "type": "string",
          "format": "date-time"
        },
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lon": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      },
      "anyOf": [
        {
          "required": ["time"]
        },
        {
          "required": ["lat", "lon"]
        }
      ]
    }
  }
}
