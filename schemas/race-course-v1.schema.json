{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://topaz-racing.com/schemas/race-course-v1.schema.json",
  "title": "Topaz Racing V1 Course",
  "description": "Race course data for Topaz Racing visualizations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "elements"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable course identifier within the race bundle."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable course name."
    },
    "elements": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered course elements rendered in sequence.",
      "items": {
        "$ref": "#/$defs/courseElement"
      }
    }
  },
  "$defs": {
    "coordinate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lat",
        "lon"
      ],
      "properties": {
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lon": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        }
      }
    },
    "courseElement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "lat",
        "lon",
        "rounding"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "mark",
            "start_line",
            "finish_line"
          ]
        },
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lon": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "rounding": {
          "type": "string",
          "enum": [
            "port",
            "starboard",
            "none"
          ]
        },
        "controlPointsToNext": {
          "type": "array",
          "description": "Optional manual route-shaping points inserted between this element and the next ordered element.",
          "items": {
            "$ref": "#/$defs/coordinate"
          }
        }
      }
    }
  }
}
